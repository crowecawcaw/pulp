# Environment variables override ~/.pulp/config.json values (see AGENTS.md "Precedence" section).

# App home directory. Overrides default ~/.pulp. Holds config.json, pulp.db, vapid.json.
# PULP_HOME=~/.pulp

# Database URL. Overrides database_path from config.json. Default: sqlite:<PULP_HOME>/pulp.db
# DATABASE_URL=sqlite:./data/pulp.db

# Server bind address. Overrides server.host:port from config.json. Default: 127.0.0.1:3000
# BIND=0.0.0.0:3000

# AI filter LLM base URL. Overrides ai_filter.base_url from config.json.
# PULP_LLM_BASE_URL=http://localhost:11434/v1

# AI filter LLM model name. Overrides ai_filter.model from config.json.
# PULP_LLM_MODEL=llama3.2

# AI filter LLM API key (bearer token). Overrides ai_filter.api_key from config.json.
# PULP_LLM_API_KEY=your-api-key-here
